# ── slushy.trade MCP server ──────────────────────────────────────────────
# Streamable-HTTP MCP transport listen address.
PORT=8788
HOST=127.0.0.1

# HyPaper backend (the paper-trading API this MCP server proxies).
#   dev:  http://localhost:3000   /   ws://localhost:3000/ws
#   prod: https://slushy.trade/api /   wss://slushy.trade/api/ws
HYPAPER_HTTP_URL=http://localhost:3000
HYPAPER_WS_URL=ws://localhost:3000/ws

# ── Active Supporter gate ─────────────────────────────────────────────────
# The deployed subscription contract on Arbitrum. NOTE: it is named
# `AdFreeSubscription` ON-CHAIN (predates the "supporter" rename and can't be
# renamed once deployed). We read its `isPaidAdFree(address)` view as the
# active-supporter check. This is the SAME address slushy-payment-watcher
# uses (its AD_FREE_CONTRACT).
SUPPORTER_CONTRACT=0xReplaceWithDeployedSubscriptionAddress
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc

# Cache an address's supporter status this many seconds (avoids hammering RPC
# on every MCP request). The on-chain expiry is still the real access window.
SUPPORTER_CACHE_TTL_SECONDS=60

# Optional escape hatch: wallets allowed WITHOUT an on-chain subscription
# (comma-separated, lowercased) — team/test wallets only. Leave blank in prod.
SUPPORTER_ALLOWLIST=
